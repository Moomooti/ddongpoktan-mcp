{
  "name": "ddongpoktan-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ddongpoktan(똥폭탄) - a chaotic KakaoTalk group-chat poop-throwing game. Remote MCP server for Kakao PlayMCP (Agentic Player 10).",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector --cli http://localhost:3000/mcp --transport http --method tools/list"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
